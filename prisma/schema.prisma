generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id         String   @id @default(cuid())
  title      String
  type       String?
  summary    String?
  content    String?
  storageKey String?
  blobUrl    String?
  status     String   @default("UPLOADED")
  errorMsg   String?
  createdAt  DateTime @default(now())

  extractions Extraction[]
  messages    ChatMessage[]
}

model Extraction {
  id         String   @id @default(cuid())
  documentId String
  data       Json

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(cuid())
  documentId String
  role       String
  content    String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}